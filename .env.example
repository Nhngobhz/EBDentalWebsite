# Copy this file to .env and adjust as needed.

# Base URL of the store-api backend (see ../store-api). Used both to call the API and
# to resolve any image/file path store-api returns as a local-disk path (/static/...)
# rather than a full R2 URL.
STORE_API_BASE_URL=http://localhost:8000

# Signs Flask's session cookie. Unrelated to store-api's own SECRET_KEY (that one signs
# JWTs) - never reuse one for the other. Generate a real one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
FLASK_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
